# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# 格式: mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL="mysql://root:password@localhost:3306/file_management"

# Prisma Configuration
# 设置为 true 可以在开发环境下显示 SQL 查询日志，false 则关闭
PRISMA_LOG_QUERIES=false

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
# 开发：本地前端 Origin，如 Vue http://localhost:5173 或 React http://localhost:5174
# 生产：必须设为真实前端地址（含 https://），例如 https://app.example.com
# 须与浏览器地址栏 Origin 完全一致（协议 + 域名 + 端口，无末尾斜杠）
# 禁止设为 * —— 本项目 cors 使用 credentials: true，* 与 credentials 不兼容且极不安全
# REST（createApp.ts）与 Socket.IO（socket.ts）生产环境均依赖此值；详见 README.md「生产部署」
CORS_ORIGIN=http://localhost:5173

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Login Rate Limit Configuration
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# API Global Rate Limit Configuration
API_RATE_LIMIT_MAX=300
API_RATE_LIMIT_WINDOW_MS=60000

REDIS_URL=redis://127.0.0.1:6379

# Storage Driver (M7)
STORAGE_DRIVER=local

# MinIO (when STORAGE_DRIVER=minio)
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=file-management