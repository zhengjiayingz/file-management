# Nest 迁移版默认 3002，避免与 Express (3000) 冲突
PORT=3002
NODE_ENV=development

DATABASE_URL="mysql://root:password@localhost:3306/file_management"
JWT_SECRET=your-secret-key-change-this-in-production
CORS_ORIGIN=http://localhost:5173

REDIS_URL=redis://127.0.0.1:6379

# 可选：Office 预览 PDF 缓存目录（默认 ../file_management_backend/previews，与 Express Worker 共用）
# PREVIEWS_PATH=../file_management_backend/previews
