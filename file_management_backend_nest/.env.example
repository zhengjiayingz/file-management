# Nest 后端（S11 后默认 3000，与前端默认一致）
PORT=3000
NODE_ENV=development

DATABASE_URL="mysql://root:password@localhost:3306/file_management"
JWT_SECRET=your-secret-key-change-this-in-production
CORS_ORIGIN=http://localhost:5173

REDIS_URL=redis://127.0.0.1:6379

# 可选：Office 预览 PDF 缓存目录（默认 ../file_management_backend/previews，与 Express Worker 共用）
# PREVIEWS_PATH=../file_management_backend/previews

# 上传目录（与 Express 共用时可指向 ../file_management_backend/uploads）
UPLOAD_PATH=../file_management_backend/uploads
STORAGE_DRIVER=local

# Docker 内连接宿主机 MySQL（docker-compose 用）
# DOCKER_DATABASE_URL=mysql://root:password@host.docker.internal:3306/file_management

# AI（划词问答 / 文档索引 / RAG / 分层摘要）
AI_API_KEY=
# 对话模型（划词 ask / RAG 生成 / Map-Reduce 摘要）
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
# DeepSeek 不支持 json_schema；后端 structured-object.util 会自动降级 json_object
# 其他 OpenAI 兼容网关若同样报错，可显式设置：
# AI_STRUCTURED_JSON_MODE=json_object
# Embedding（索引 / RAG 检索）。DeepSeek 无 /embeddings，需单独配置 OpenAI 兼容服务，例如：
# AI_EMBEDDING_BASE_URL=https://api.openai.com/v1
# AI_EMBEDDING_API_KEY=sk-...
# 或硅基流动：
# AI_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# AI_EMBEDDING_API_KEY=sk-...
# AI_EMBEDDING_MODEL=BAAI/bge-m3
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_INDEX_CHUNKS=500
# 期刊论文（paper）知识卡片：每个字段组 RAG 检索片段数（默认 12；不影响小说/通识摘要）
# AI_PAPER_KNOWLEDGE_TOP_K=12
AI_DAILY_ASK_LIMIT=100

# 视觉 OCR（F-26 图片可索引）。走硅基流动，勿用 api.deepseek.com（无 DeepSeek-OCR）
# Key 与 AI_EMBEDDING_API_KEY 可为同一把硅基流动密钥
AI_VISION_BASE_URL=https://api.siliconflow.cn/v1
AI_VISION_API_KEY=
AI_VISION_MODEL=deepseek-ai/DeepSeek-OCR

# 截图解题 VL（F-27，实施时启用；与 OCR 分模型）
AI_MATH_VISION_BASE_URL=https://api.siliconflow.cn/v1
AI_MATH_VISION_API_KEY=
AI_MATH_VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct

# F-30：扫描 PDF OCR 页数上限
AI_MAX_OCR_PDF_PAGES=50

# F-38 以图搜图（视觉 Embedding；Key 可与 AI_EMBEDDING_API_KEY 相同）
# AI_IMAGE_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# AI_IMAGE_EMBEDDING_API_KEY=
AI_IMAGE_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-8B

# 临时截图 TTL（小时），插件 / math-temp 中间态
AI_MATH_TEMP_TTL_HOURS=24

