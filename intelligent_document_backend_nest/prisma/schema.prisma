// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique @db.VarChar(50)
  password       String   @db.VarChar(64)
  email          String?  @unique @db.VarChar(100)
  /// 头像 URL 路径，如 /uploads/avatars/xxx.jpg（可为空）
  avatarUrl      String?  @map("avatar_url") @db.VarChar(500)
  role           Role     @default(user)
  storageQuota   BigInt   @map("storage_quota")
  storageUsed    BigInt   @default(0) @map("storage_used")
  status         Status   @default(active)
  /// 管理员重置为临时密码后，为 true；用户修改为符合策略的密码后为 false
  mustChangePassword Boolean @default(false) @map("must_change_password")
  /// 会话版本：递增后此前签发的 Access Token 全部失效（踢人、改密、禁用等）
  sessionVersion Int @default(0) @map("session_version")
  /// 管理员「踢出登录」标记时间；登录成功会清空，供管理端「登录状态」开关展示
  lastSessionKickAt DateTime? @map("last_session_kick_at")
  vipExpireAt    DateTime? @map("vip_expire_at")
  /// 管理员可选：TOTP 两步验证已启用
  totpEnabled    Boolean  @default(false) @map("totp_enabled")
  /// 是否开通预览「划词朗读」；独立 TTS 页不依赖此字段。管理员逻辑上始终可用划词朗读
  ttsEnabled     Boolean  @default(false) @map("tts_enabled")
  /// 已激活的 TOTP 密钥（Base32）；仅当 totpEnabled 为 true 时有值
  totpSecret     String?  @map("totp_secret") @db.VarChar(64)
  /// 设置流程中的临时密钥，确认前未生效
  totpSetupSecret String? @map("totp_setup_secret") @db.VarChar(64)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  userFiles      UserFile[]
  fileShares     FileShare[]
  sentFriendships     Friendship[] @relation("UserFriendships")
  receivedFriendships Friendship[] @relation("FriendFriendships")
  sentMessages   Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  fileTags       FileTag[]
  operationLogs  OperationLog[]
  loginLogs      LoginLog[]
  refreshTokens  RefreshToken[]
  uploadChunks   UploadChunk[]
  shareAccessLogs ShareAccessLog[]
  userPreference UserPreference?
  vipUpgradeRequestsAsApplicant VipUpgradeRequest[] @relation("VipApplicant")
  vipUpgradeRequestsProcessed   VipUpgradeRequest[] @relation("VipProcessedBy")
  knowledgeBases KnowledgeBase[]
  wrongQuestionBookItems WrongQuestionBookItem[]
  fileAiChatSessions FileAiChatSession[]
  mathTempImages MathTempImage[]
  tempAiChatSessions TempAiChatSession[]
  fileFingerprints FileFingerprint[]

  @@map("users")
}

/// 用户申请升级 VIP（管理员在通讯录中审核）
model VipUpgradeRequest {
  id            Int               @id @default(autoincrement())
  applicantId   Int               @map("applicant_id")
  status        VipUpgradeStatus  @default(pending)
  processedById Int?              @map("processed_by_id")
  processedAt   DateTime?       @map("processed_at")
  createdAt     DateTime          @default(now()) @map("created_at")

  applicant   User @relation("VipApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  processedBy User? @relation("VipProcessedBy", fields: [processedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([applicantId, status])
  @@map("vip_upgrade_requests")
}

enum VipUpgradeStatus {
  pending
  approved
  rejected
}

model UserPreference {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  locale    String   @default("auto") @db.VarChar(10)  // 'zh-CN', 'zh-TW', 'en-US', 'auto'
  theme     String   @default("auto") @db.VarChar(10)  // 'light', 'dark', 'auto'
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

/// 全局系统配置（单行 id=1）：密码策略、按角色默认空间、标签上限等
model SystemSettings {
  id Int @id @default(1)

  /// 密码最短长度
  passwordMinLength     Int @default(8) @map("password_min_length")
  /// 须同时满足的字符类别（JSON 数组，元素为 digit | lower | upper | special）
  passwordRequiredCategories Json @default("[\"digit\",\"lower\",\"upper\",\"special\"]") @map("password_required_categories")
  /// 在已勾选的类别中，密码至少须满足其中几类（1～勾选数量，可与勾选数相等表示全部须满足）
  passwordMinCategoriesInPool Int @default(4) @map("password_min_categories_in_pool")

  /// 普通用户默认空间（字节）
  storageQuotaUserBytes  BigInt @default(1073741824) @map("storage_quota_user_bytes")
  /// VIP 用户默认/升级后空间（字节）
  storageQuotaVipBytes   BigInt @default(2147483648) @map("storage_quota_vip_bytes")
  /// 管理员默认空间（字节）
  storageQuotaAdminBytes BigInt @default(107374182400) @map("storage_quota_admin_bytes")

  maxTagsUser Int @default(2) @map("max_tags_user")
  maxTagsVip  Int @default(5) @map("max_tags_vip")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model FileStorage {
  id              Int      @id @default(autoincrement())
  fileHash        String   @unique @map("file_hash") @db.VarChar(64)
  filePath        String   @map("file_path") @db.VarChar(500) // 相对项目根，如 uploads/...
  fileSize        BigInt   @map("file_size")
  mimeType        String   @map("mime_type") @db.VarChar(100)
  referenceCount  Int      @default(0) @map("reference_count")
  status          FileStatus @default(active)
  markedDeleteAt  DateTime? @map("marked_delete_at")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  userFiles       UserFile[]
  // uploadChunks    UploadChunk[]
  fileHistories   FileHistory[]

  @@map("file_storage")
}

model UserFile {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  storageId  Int?     @map("storage_id")
  parentId   Int?     @map("parent_id")
  fileName   String   @map("file_name") @db.VarChar(255)
  fileType   FileType @map("file_type")
  isDeleted  Boolean  @default(false) @map("is_deleted")
  version    Int      @default(1)
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  // fields: [本表的外键列],      // 存关联 ID 的列
  // references: [对方表的主键],  // 通常就是 id
  // onDelete: Cascade            // 删对方时怎么处理（可选）
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storage    FileStorage? @relation(fields: [storageId], references: [id], onDelete: SetNull)
  // 同一个 model 和自己（或和别人）有多条关系时，必须起名字区。"UserFileHierarchy" 只是关系名，不是表名，用来配对两条边。
  // parent：我是谁的子节点（用 parentId）
  parent     UserFile? @relation("UserFileHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children   UserFile[] @relation("UserFileHierarchy") // children：谁是我的子节点（反向）

  fileShares FileShare[] // 外键在 file_shares.user_file_id → 不用写
  userFileTags UserFileTag[]
  fileHistories FileHistory[]
  messages   Message[]
  documentIndexJob DocumentIndexJob?
  documentChunks   DocumentChunk[]
  documentSummaries DocumentSummary[]
  documentKnowledge DocumentKnowledge?
  knowledgeBaseItems KnowledgeBaseItem[]
  wrongQuestionBookItems WrongQuestionBookItem[]
  fileAiChatSessions FileAiChatSession[]
  fileFingerprint FileFingerprint?

  @@index([userId, parentId, isDeleted])
  @@index([storageId])
  @@map("user_files")
}

model UploadChunk {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  fileHash   String   @map("file_hash") @db.VarChar(64)
  chunkIndex Int      @map("chunk_index")
  chunkHash  String   @map("chunk_hash") @db.VarChar(64)
  chunkSize  Int      @map("chunk_size")
  chunkPath  String   @map("chunk_path") @db.VarChar(500) // 相对项目根 chunks/...
  status     ChunkStatus @default(uploading)
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // storage    FileStorage? @relation(fields: [fileHash], references: [fileHash])

  @@unique([fileHash, chunkIndex])
  @@index([userId, fileHash])
  @@map("upload_chunks")
}

model FileShare {
  id               Int      @id @default(autoincrement())
  userId           Int      @map("user_id")
  userFileId       Int      @map("user_file_id")
  /// 批量分享时的全部 user_files.id（JSON 数组）；与 userFileId（首项）同时写入便于校验与扩展
  userFileIds      Json?    @map("user_file_ids")
  shareCode        String   @unique @map("share_code") @db.VarChar(32)
  extractCode      String?  @map("extract_code") @db.VarChar(6)
  permission       SharePermission @default(download)
  expireAt         DateTime? @map("expire_at")
  /// 是否将提取码附加在分享 URL 查询参数中（访客端解析用）
  autoFillExtract  Boolean  @default(false) @map("auto_fill_extract")
  /// 访问人数上限；null 表示不限制（按独立访客 IP 计数，见 share.controller）
  maxVisitors      Int?     @map("max_visitors")
  viewCount        Int      @default(0) @map("view_count")
  downloadCount    Int      @default(0) @map("download_count")
  status           ShareStatus @default(active)
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userFile      UserFile @relation(fields: [userFileId], references: [id], onDelete: Cascade)
  accessLogs    ShareAccessLog[]

  @@index([userId])
  @@index([status, expireAt])
  @@map("file_shares")
}

model ShareAccessLog {
  id         Int      @id @default(autoincrement())
  shareId    Int      @map("share_id")
  visitorId  Int?     @map("visitor_id")
  ipAddress  String   @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  action     AccessAction
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  share      FileShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  visitor    User?     @relation(fields: [visitorId], references: [id], onDelete: SetNull)

  @@index([shareId, createdAt])
  @@map("share_access_logs")
}

model Friendship {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  friendId  Int      @map("friend_id")
  status    FriendshipStatus @default(pending)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user      User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([friendId, status])
  @@map("friendships")
}

model Message {
  id          Int      @id @default(autoincrement())
  senderId    Int      @map("sender_id")  //发送者Id
  receiverId  Int      @map("receiver_id")//接收者Id
  content     String   @db.Text
  messageType MessageType @default(text) @map("message_type")
  fileId      Int?     @map("file_id") // 文件消息关联 UserFile
  isRead      Boolean  @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  file        UserFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([receiverId, isRead, createdAt])
  @@index([senderId, createdAt])
  @@map("messages")
}

model FileTag {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tagName   String   @map("tag_name") @db.VarChar(50)
  color     String?  @db.VarChar(7)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userFileTags UserFileTag[]

  @@unique([userId, tagName])
  @@map("file_tags")
}

model UserFileTag {
  id         Int      @id @default(autoincrement())
  userFileId Int      @map("user_file_id")
  tagId      Int      @map("tag_id")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  userFile   UserFile @relation(fields: [userFileId], references: [id], onDelete: Cascade)
  tag        FileTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([userFileId, tagId])
  @@index([tagId])
  @@map("user_file_tags")
}

model OperationLog {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  operationType String   @map("operation_type") @db.VarChar(50)
  resourceType  String   @map("resource_type") @db.VarChar(50)
  resourceId    Int?     @map("resource_id")
  description   String?  @db.VarChar(500)
  ipAddress     String   @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([operationType, createdAt])
  @@map("operation_logs")
}

model LoginLog {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  username   String?  @map("username") @db.VarChar(50)
  ipAddress  String   @map("ip_address") @db.VarChar(45)
  location   String?  @db.VarChar(100)
  device     String?  @db.VarChar(100)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  status     LoginStatus
  failReason String?  @map("fail_reason") @db.VarChar(200)
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([ipAddress, createdAt])
  @@index([username])
  @@map("login_logs")
}

model RefreshToken {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  token       String   @unique @db.VarChar(500)
  deviceName  String?  @map("device_name") @db.VarChar(100)
  deviceType  String?  @map("device_type") @db.VarChar(50)
  ipAddress   String   @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  isRevoked   Boolean  @default(false) @map("is_revoked")
  expiresAt   DateTime @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRevoked, expiresAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model FileHistory {
  id            Int      @id @default(autoincrement())
  userFileId    Int      @map("user_file_id")
  storageId     Int      @map("storage_id")
  fileName      String   @map("file_name") @db.VarChar(255)
  version       Int      @map("version")
  fileSize      BigInt   @map("file_size")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  userFile      UserFile @relation(fields: [userFileId], references: [id], onDelete: Cascade)
  storage       FileStorage @relation(fields: [storageId], references: [id], onDelete: Cascade)

  @@index([userFileId, version])
  @@map("file_histories")
}

model DocumentKnowledge {
  id         Int      @id @default(autoincrement())
  userFileId Int      @unique @map("user_file_id")
  payload    Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  userFile UserFile @relation(fields: [userFileId], references: [id], onDelete: Cascade)

  @@map("document_knowledge")
}

model KnowledgeBase {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    KnowledgeBaseItem[]
  sessions KnowledgeBaseSession[]
  @@index([userId, updatedAt])
  @@map("knowledge_bases")
}
model KnowledgeBaseItem {
  id              Int      @id @default(autoincrement())
  knowledgeBaseId Int      @map("knowledge_base_id")
  userFileId      Int      @map("user_file_id")
  createdAt       DateTime @default(now()) @map("created_at")
  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  userFile      UserFile      @relation(fields: [userFileId], references: [id], onDelete: Cascade)
  @@unique([knowledgeBaseId, userFileId])
  @@index([userFileId])
  @@map("knowledge_base_items")
}
model KnowledgeBaseSession {
  id              Int      @id @default(autoincrement())
  knowledgeBaseId Int      @map("knowledge_base_id")
  title           String?  @db.VarChar(200)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  knowledgeBase KnowledgeBase          @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  messages      KnowledgeBaseMessage[]
  @@index([knowledgeBaseId, updatedAt])
  @@map("knowledge_base_sessions")
}
model KnowledgeBaseMessage {
  id        Int                      @id @default(autoincrement())
  sessionId Int                      @map("session_id")
  role      KnowledgeBaseMessageRole
  content   String                   @db.Text
  /// assistant 消息：RAG citations JSON；user 消息一般为 null
  citations Json?
  createdAt DateTime                 @default(now()) @map("created_at")
  session KnowledgeBaseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  @@index([sessionId, createdAt])
  @@map("knowledge_base_messages")
}

// Enums
enum KnowledgeBaseMessageRole {
  user
  assistant
}

/// 网盘文件预览 AI 对话模式（划词 / RAG / 解题）
enum FileAiChatMode {
  selection
  rag
  solve
}

enum FileAiChatRole {
  user
  assistant
}

/// 单文件 × 模式 一条会话（预览对话落盘）
model FileAiChatSession {
  id         Int            @id @default(autoincrement())
  userId     Int            @map("user_id")
  userFileId Int            @map("user_file_id")
  mode       FileAiChatMode
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userFile UserFile            @relation(fields: [userFileId], references: [id], onDelete: Cascade)
  messages FileAiChatMessage[]

  @@unique([userId, userFileId, mode])
  @@index([userFileId, mode])
  @@map("file_ai_chat_sessions")
}

model FileAiChatMessage {
  id        Int            @id @default(autoincrement())
  sessionId Int            @map("session_id")
  role      FileAiChatRole
  content   String         @db.Text
  /// selection：划词片段；rag：可选 citations
  meta      Json?
  createdAt DateTime       @default(now()) @map("created_at")

  session FileAiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("file_ai_chat_messages")
}

enum Role {
  user
  vip
  admin
}

enum Status {
  active
  disabled
}

enum FileStatus {
  active
  pending_delete
}

enum FileType {
  file
  folder
}

enum ChunkStatus {
  uploading
  completed
  failed
}

enum SharePermission {
  view
  download
  edit
}

enum ShareStatus {
  active
  expired
  cancelled
}

enum AccessAction {
  view
  download
  save
}

enum FriendshipStatus {
  pending
  accepted
  rejected
  blocked
}

enum MessageType {
  text
  file
}

enum LoginStatus {
  success
  failed
}

// --- Document Intelligence (S12 index; Summary/Knowledge deferred to S13/S14) ---

enum DocumentIndexStatus {
  pending
  extracting
  chunking
  embedding
  summarizing
  extracting_knowledge
  ready
  failed
}

enum DocumentIndexMode {
  general
  academic
}

enum DocumentChunkSection {
  unknown
  abstract
  introduction
  method
  results
  discussion
  references
  body
  chapter
}

enum SummaryGenre {
  novel
  general_nonfiction
  technical
  textbook
  lab_report
  paper
}

enum DocumentSummaryType {
  chunk
  chapter
  book
  theme
}

model DocumentIndexJob {
  id           Int                  @id @default(autoincrement())
  userFileId   Int                  @unique @map("user_file_id")
  mode         DocumentIndexMode
  status       DocumentIndexStatus  @default(pending)
  progress     Int                  @default(0)        // 0-100
  progressMsg  String?              @map("progress_msg") @db.VarChar(255)
  errorMessage String?              @map("error_message") @db.Text
  chunkCount   Int                  @default(0) @map("chunk_count")
  indexedFileHash String?           @map("indexed_file_hash") @db.VarChar(64)
  summaryGenre SummaryGenre?        @map("summary_genre")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  userFile UserFile @relation(fields: [userFileId], references: [id], onDelete: Cascade)

  @@map("document_index_jobs")
}

model DocumentChunk {
  id          Int                   @id @default(autoincrement())
  userFileId  Int                   @map("user_file_id")
  chunkIndex  Int                   @map("chunk_index")
  section     DocumentChunkSection  @default(body)
  sectionTitle String?              @map("section_title") @db.VarChar(255)
  chapterNo   Int?                  @map("chapter_no")
  content     String                @db.Text
  startMs     Int?                  @map("start_ms")
  endMs       Int?                  @map("end_ms")
  tokenEstimate Int?                @map("token_estimate")
  embedding   Json?                 // number[]，MVP 存 MySQL；量大迁向量库
  createdAt   DateTime              @default(now()) @map("created_at")

  userFile UserFile @relation(fields: [userFileId], references: [id], onDelete: Cascade)

  @@unique([userFileId, chunkIndex])
  @@index([userFileId, section])
  @@map("document_chunks")
}

enum FileFingerprintStatus {
  pending
  ready
  failed
}

/// F-38 图片视觉指纹（以图搜图）；MVP 搜索时按需 embed 并缓存
model FileFingerprint {
  id             Int                   @id @default(autoincrement())
  userFileId     Int                   @unique @map("user_file_id")
  userId         Int                   @map("user_id")
  /// 视觉 embedding（number[]）；与文本 embedding 模型不同
  imageEmbedding Json?                 @map("image_embedding")
  status         FileFingerprintStatus @default(pending)
  errorMessage   String?               @map("error_message") @db.VarChar(500)
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  userFile UserFile @relation(fields: [userFileId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("file_fingerprints")
}

model DocumentSummary {
  id         Int                 @id @default(autoincrement())
  userFileId Int                 @map("user_file_id")
  type       DocumentSummaryType
  refKey     String              @map("ref_key") @db.VarChar(64)
  payload    Json
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  userFile UserFile @relation(fields: [userFileId], references: [id], onDelete: Cascade)
  @@unique([userFileId, type, refKey])
  @@map("document_summaries")
}
/// F-29 错题本条目；userFileId 可空预留 F-29+ temp 转正，MVP 创建业务校验必填
model WrongQuestionBookItem {
  id           Int                     @id @default(autoincrement())
  userId       Int                     @map("user_id")
  userFileId   Int?                    @map("user_file_id")
  questionText String                  @map("question_text") @db.Text
  answerText   String                  @map("answer_text") @db.Text
  tags         Json                    @default("[]")
  /// 难度：简单 / 中档 / 困难
  difficulty   WrongQuestionDifficulty @default(medium)
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userFile UserFile? @relation(fields: [userFileId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, difficulty])
  @@index([userFileId])
  @@map("wrong_question_book_items")
}

enum WrongQuestionDifficulty {
  easy
  medium
  hard
}

/// F-29+ / 插件：临时解题图（不出现在网盘列表）
model MathTempImage {
  id           Int       @id @default(autoincrement())
  tempImageId  String    @unique @map("temp_image_id") @db.VarChar(64)
  userId       Int       @map("user_id")
  storageKey   String    @map("storage_key") @db.VarChar(500)
  mime         String    @db.VarChar(100)
  originalName String?   @map("original_name") @db.VarChar(255)
  fileSize     BigInt    @map("file_size")
  expiresAt    DateTime  @map("expires_at")
  consumedAt   DateTime? @map("consumed_at")
  /// 转正后的网盘文件（存网盘 / 存错题本）
  promotedUserFileId Int? @map("promoted_user_file_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions TempAiChatSession[]

  @@index([userId, expiresAt])
  @@map("math_temp_images")
}

/// 临时图上的对话（与 FileAiChatSession 对称；mode 实际用 selection / solve）
model TempAiChatSession {
  id          Int            @id @default(autoincrement())
  userId      Int            @map("user_id")
  tempImageId String         @map("temp_image_id") @db.VarChar(64)
  mode        FileAiChatMode
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tempImage MathTempImage     @relation(fields: [tempImageId], references: [tempImageId], onDelete: Cascade)
  messages TempAiChatMessage[]

  @@unique([userId, tempImageId, mode])
  @@index([tempImageId, mode])
  @@map("temp_ai_chat_sessions")
}

model TempAiChatMessage {
  id        Int            @id @default(autoincrement())
  sessionId Int            @map("session_id")
  role      FileAiChatRole
  content   String         @db.Text
  meta      Json?
  createdAt DateTime       @default(now()) @map("created_at")

  session TempAiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("temp_ai_chat_messages")
}
